theme = GitHub Dark High Contrast

# Pane
keybind = alt+h=text:\x1b\x7f
keybind = shift+enter=text:\x1b\r
keybind = shift+space=text:\x20

# Cursor
keybind = alt+f=esc:f
keybind = alt+b=esc:b

# Appearance
font-size = 14
unfocused-split-opacity = 0.9
background-opacity = 0.95

# General
font-feature = -dlig
# 端末の桁幅計算を wcswidth ベースにし、tmux/Emacs と一致させる
# (デフォルトの unicode だと全角・曖昧幅文字で桁ズレが累積し、
#  tmux 内 Emacs の折り返し表示行がずれるため)
grapheme-width-method = legacy
window-inherit-working-directory = true
macos-titlebar-style = transparent
macos-option-as-alt = left

# SSH
shell-integration-features = no-cursor,no-sudo,title,path
